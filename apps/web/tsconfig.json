{
  "extends": "../../packages/tsconfig/next.json",
  "compilerOptions": {
    "baseUrl": "../frontend",
    "paths": {
      "@/*": ["./src/*"]
    },
    "incremental": true,
    "plugins": [{ "name": "next" }]
  },
  "include": [
    "../frontend/next-env.d.ts",
    "../frontend/src/**/*",
    "../frontend/.next/types/**/*.ts"
  ],
  "exclude": ["../frontend/node_modules", "../frontend/.next", "../frontend/dist"]
}
